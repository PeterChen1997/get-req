OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o

NOTION_TOKEN=ntn_xxx
# 预览版页面的父页面，需手动设为 Public（Share to web）
NOTION_PARENT_PAGE_ID=your-notion-page-id
# 完整版页面的父页面，必须保持 Private，不要设为公开分享
NOTION_PRIVATE_PARENT_PAGE_ID=your-private-notion-page-id

OPERATOR_WECHAT=your_wechat_id

# 运营后台（/admin 及管理类 API）访问密钥
ADMIN_SECRET=change-me-to-a-strong-secret

# —— Exa 联网搜索（用于 AI 查证行业现成方案/最新做法）——
# 未配置时 webSearch 工具优雅降级为不可用，不影响其它功能
EXA_API_KEY=your-exa-key
# 每个会话允许的搜索次数上限
SEARCH_MAX_PER_SESSION=15

# —— 成本管理（以下均有代码内默认值，可不配置）——
# L1 请求级：单条用户消息字符上限 / 单次请求 messages 条数上限 / 单次回复输出 token 上限
CHAT_MAX_MESSAGE_CHARS=4000
CHAT_MAX_MESSAGES=120
CHAT_MAX_OUTPUT_TOKENS=2048
# L2 会话软阈值：达到后引导 AI 收敛并准备生成文档（轮数 或 累计输入 token 任一触发）
CHAT_SOFT_TURNS=30
CHAT_SOFT_INPUT_TOKENS=200000
# L2 会话硬阈值：达到后强制本轮生成文档（轮数 或 累计输入 token 任一触发）
CHAT_HARD_TURNS=45
CHAT_HARD_INPUT_TOKENS=350000
# 硬阈值后允许的强制生成文档请求次数（防 Notion 反复失败无限烧钱）
CHAT_HARD_GRACE=2
# 文档生成后允许的追问轮数，超过则锁定会话
CHAT_POST_DOC_TURNS=5
# 会话时效（天），超过则 session 失效
SESSION_MAX_AGE_DAYS=7
# L4 全站当日成本熔断（美元，UTC 日界）
DAILY_BUDGET_USD=10
# L4 同一会话每分钟请求次数上限
RATE_LIMIT_PER_MINUTE=6

# —— 单价（仅用于成本折算展示，调价不影响已落库的 token 数）——
PRICE_INPUT_USD_PER_1M=2.5
PRICE_OUTPUT_USD_PER_1M=10
PRICE_EXA_PER_SEARCH_USD=0.005
