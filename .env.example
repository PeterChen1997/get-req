OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o

NOTION_TOKEN=ntn_xxx
# 预览版页面的父页面，需手动设为 Public（Share to web）
NOTION_PARENT_PAGE_ID=your-notion-page-id
# 完整版页面的父页面，必须保持 Private，不要设为公开分享
NOTION_PRIVATE_PARENT_PAGE_ID=your-private-notion-page-id

OPERATOR_WECHAT=your_wechat_id

# 运营后台（/admin 及管理类 API）访问密钥
ADMIN_SECRET=change-me-to-a-strong-secret
